# Copia este archivo a .env.local y ajusta los valores segun tu entorno.
# Si omites NEXT_PUBLIC_PROGRAM_ID, el frontend usa el Program ID demo
# que ya viene como fallback en el codigo para devnet.
# NEXT_PUBLIC_PROGRAM_ID=REEMPLAZA_CON_TU_PROGRAM_ID

NEXT_PUBLIC_RPC_URL=https://api.devnet.solana.com

# URL base del sitio para metadata/Open Graph.
# En produccion, cambiala por tu dominio publico.
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# URL publica usada por los Blinks/Actions.
# En local puede quedarse asi; en Codespaces o produccion debes poner
# una URL publica accesible desde internet.
NEXT_PUBLIC_APP_URL=http://localhost:3000
